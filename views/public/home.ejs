<%- include('../layout/header') %>

    <div class="hero">
        <div class="hero-box">
            <h1>Dibujos gratis para Imprimir y Colorear</h1>
            <p>Descarga gratis dibujos para colorear de diferentes categorías. Todos los diseños listos para imprimir.
            </p>
        </div>
    </div>

    <section class="featured-categories">
        <h2 class="section-title">Categorías Destacadas</h2>
        <div class="category-slider-wrapper">
            <button class="slider-btn prev" id="slider-prev">❮</button>
            <div class="category-grid slider-mode" id="category-slider">
                <% categories.forEach(cat=> { %>
                    <a href="/categoria/<%= cat.slug %>" class="category-card">
                        <div class="category-icon">
                            <svg class="icon-svg" viewBox="0 0 24 24" style="width: 50px; height: 50px;">
                                <path
                                    d="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" />
                            </svg>
                        </div>
                        <div class="category-info">
                            <h3>
                                <%= cat.name %>
                            </h3>
                        </div>
                    </a>
                    <% }) %>
            </div>
            <button class="slider-btn next" id="slider-next">❯</button>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const slider = document.getElementById('category-slider');
            const prevBtn = document.getElementById('slider-prev');
            const nextBtn = document.getElementById('slider-next');

            if (slider && prevBtn && nextBtn) {
                const scrollAmount = 300;

                prevBtn.addEventListener('click', () => {
                    slider.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
                });

                nextBtn.addEventListener('click', () => {
                    slider.scrollBy({ left: scrollAmount, behavior: 'smooth' });
                });

                const wrapper = document.querySelector('.category-slider-wrapper');
                const toggleArrows = () => {
                    const isAtStart = slider.scrollLeft <= 5;
                    const isAtEnd = slider.scrollLeft + slider.clientWidth >= slider.scrollWidth - 5;

                    prevBtn.style.display = isAtStart ? 'none' : 'flex';
                    nextBtn.style.display = isAtEnd ? 'none' : 'flex';

                    // Toggle G gradients
                    if (wrapper) {
                        wrapper.classList.toggle('show-left-fade', !isAtStart);
                        wrapper.classList.toggle('show-right-fade', !isAtEnd);
                    }
                };

                slider.addEventListener('scroll', toggleArrows);
                window.addEventListener('resize', toggleArrows);
                setTimeout(toggleArrows, 500);
            }
        });
    </script>

    <section class="recent-drawings">
        <h2 class="section-title">Últimos dibujos añadidos</h2>
        <div class="grid">
            <% images.forEach(img=> { %>
                <div class="card">
                    <a href="/dibujo/<%= img.slug %>">
                        <% const displaySrc=img.cloudinary_url ||
                            `/assets/images/webp/${img.category_slug}/${img.filename}.webp`; %>
                            <img src="<%= displaySrc %>" alt="<%= img.alt_text %>" loading="lazy">
                    </a>
                    <div class="card-info">
                        <div class="card-header">
                            <h3 class="card-title">
                                <%= img.title %>
                            </h3>
                            <span class="card-category">
                                <%= img.category_name %>
                            </span>
                        </div>
                        <div class="card-actions">
                            <a href="/dibujo/<%= img.slug %>" class="btn btn-view">Ver</a>
                            <% 
                                const downloadSrc = img.cloudinary_url 
                                    ? img.cloudinary_url.replace(/\.webp$/, '.jpg') 
                                    : `/assets/images/jpg/${img.category_slug}/${img.filename}.jpg`; 
                            %>
                            <a href="<%= downloadSrc %>" download="<%= img.slug %>.jpg" class="btn btn-download-sq"
                                title="Descargar JPG">
                                    <svg class="icon-svg" viewBox="0 0 24 24" fill="#ffffff">
                                        <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" />
                                    </svg>
                                </a>
                        </div>
                    </div>
                </div>
                <% }) %>
        </div>
        <% if (typeof hasMore !=='undefined' && hasMore) { %>
            <div id="load-more-container" style="text-align: center; margin-top: 4rem; margin-bottom: 4rem;">
                <% const safeBaseUrl=locals.baseUrl || '/' ; const safeCurrentPage=locals.currentPage || 1; const
                    sep=safeBaseUrl.includes('?') ? '&' : '?' ; const
                    nextUrl=`${safeBaseUrl}${sep}page=${safeCurrentPage + 1}`; %>
                    <a href="<%= nextUrl %>" id="load-more-btn" class="btn btn-primary">
                        Ver más dibujos
                    </a>
            </div>
            <% } %>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const btn = document.getElementById('load-more-btn');
            const grid = document.querySelector('.grid');
            const container = document.getElementById('load-more-container');

            if (!btn) return;

            btn.addEventListener('click', async (e) => {
                e.preventDefault();
                const url = btn.getAttribute('href');
                btn.textContent = 'Cargando... ⏳';
                btn.style.opacity = '0.7';
                btn.style.pointerEvents = 'none';

                try {
                    const response = await fetch(url);
                    const text = await response.text();
                    const parser = new DOMParser();
                    const html = parser.parseFromString(text, 'text/html');

                    // Extraer nuevas tarjetas
                    const newCards = html.querySelectorAll('.grid .card');
                    newCards.forEach(card => {
                        grid.appendChild(card);
                    });

                    // Actualizar o eliminar botón
                    const newBtn = html.getElementById('load-more-btn');
                    if (newBtn) {
                        btn.setAttribute('href', newBtn.getAttribute('href'));
                        btn.textContent = 'Ver más dibujos';
                        btn.style.opacity = '1';
                        btn.style.pointerEvents = 'auto';
                    } else {
                        container.remove();
                    }
                } catch (err) {
                    console.error('Error:', err);
                    window.location.href = url; // Fallback
                }
            });
        });
    </script>

    <section class="info-section accordion-section">
        <div class="info-content">
            <h2 class="accordion-main-title">Información para Padres y Educadores</h2>
            
            <div class="accordion">
                <div class="accordion-item">
                    <button class="accordion-header" aria-expanded="false">
                        <span class="accordion-title">🎨 Beneficios del Coloreado</span>
                        <span class="accordion-icon"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span>
                    </button>
                    <div class="accordion-content">
                        <div class="accordion-content-inner">
                            <p>
                                Colorear es una actividad esencial para el desarrollo de la <strong>motricidad fina</strong> y la coordinación. 
                                En PintaColores, cada dibujo está diseñado para estimular la creatividad y la concentración de los niños de forma divertida y gratuita.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <button class="accordion-header" aria-expanded="false">
                        <span class="accordion-title">🚀 Creatividad sin Límites</span>
                        <span class="accordion-icon"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span>
                    </button>
                    <div class="accordion-content">
                        <div class="accordion-content-inner">
                            <p>
                                Desde animales tiernos hasta naves espaciales, nuestra galería se actualiza constantemente. Ofrecemos contenido 
                                único y original para que siempre haya una nueva aventura esperando ser pintada.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <button class="accordion-header" aria-expanded="false">
                        <span class="accordion-title">🖨️ Guía de Uso</span>
                        <span class="accordion-icon"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span>
                    </button>
                    <div class="accordion-content">
                        <div class="accordion-content-inner">
                            <p>
                                Nuestra plataforma es 100% segura. Solo tienes que elegir un dibujo, descargarlo como JPG de alta calidad 
                                o imprimirlo directamente. Todos los diseños están optimizados para papel A4.
                            </p>
                            <ul class="accordion-list">
                                <li><strong>1.</strong> Navega por las categorías.</li>
                                <li><strong>2.</strong> Selecciona tu dibujo favorito.</li>
                                <li><strong>3.</strong> ¡Descarga o imprime y a pintar!</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <button class="accordion-header" aria-expanded="false">
                        <span class="accordion-title">🌟 Nuestro Compromiso</span>
                        <span class="accordion-icon"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span>
                    </button>
                    <div class="accordion-content">
                        <div class="accordion-content-inner">
                            <p>
                                Trabajamos para ofrecer la mejor colección de dibujos para imprimir. Cada trazo está cuidado para asegurar 
                                que los niños tengan una experiencia de coloreado óptima y gratificante.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <style>
        .accordion-section {
            padding: 4rem 1rem;
            background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);
            border-radius: var(--radius-lg, 24px);
            margin: 4rem auto;
            max-width: 900px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.02);
            border: 1px solid rgba(255, 255, 255, 0.4);
        }

        .accordion-main-title {
            text-align: center;
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--text, #2d3748);
            margin-bottom: 2.5rem;
            letter-spacing: -0.5px;
        }

        .accordion {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .accordion-item {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
            transition: all 0.3s ease;
            border: 1px solid transparent;
        }

        .accordion-item:hover {
            box-shadow: 0 8px 25px rgba(0,0,0,0.06);
            transform: translateY(-2px);
            border-color: rgba(99, 102, 241, 0.1);
        }

        .accordion-header {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.25rem 1.5rem;
            background: transparent;
            border: none;
            cursor: pointer;
            text-align: left;
            transition: background-color 0.3s ease;
        }

        .accordion-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--text, #1a202c);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .accordion-icon {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: #f3f4f6;
            color: #6b7280;
            transition: all 0.3s ease;
        }

        .accordion-header[aria-expanded="true"] .accordion-icon {
            transform: rotate(180deg);
            background: #eef2ff;
            color: #4f46e5;
        }

        .accordion-header[aria-expanded="true"] .accordion-title {
            color: #4f46e5;
        }

        .accordion-content {
            display: grid;
            grid-template-rows: 0fr;
            transition: grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            background: #fafafa;
        }

        .accordion-header[aria-expanded="true"] + .accordion-content {
            grid-template-rows: 1fr;
        }

        .accordion-content-inner {
            overflow: hidden;
            padding: 0 1.5rem;
            opacity: 0;
            transition: opacity 0.3s ease, padding 0.3s ease;
        }

        .accordion-header[aria-expanded="true"] + .accordion-content .accordion-content-inner {
            padding: 0 1.5rem 1.5rem 1.5rem;
            opacity: 1;
            transition-delay: 0.1s;
        }

        .accordion-content p {
            margin: 0;
            line-height: 1.7;
            color: #4b5563;
            font-size: 1.05rem;
        }

        .accordion-list {
            margin-top: 1rem;
            padding-left: 0;
            list-style: none;
        }

        .accordion-list li {
            margin-bottom: 0.5rem;
            color: #4b5563;
            font-size: 1.05rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .accordion-list li strong {
            color: #4f46e5;
            background: #eef2ff;
            width: 24px;
            height: 24px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 0.85rem;
        }

        @media (max-width: 768px) {
            .accordion-section {
                padding: 2.5rem 1rem;
                margin: 2rem 1rem;
            }
            .accordion-main-title {
                font-size: 1.8rem;
            }
            .accordion-title {
                font-size: 1.05rem;
            }
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const accordionHeaders = document.querySelectorAll('.accordion-header');
            
            accordionHeaders.forEach(header => {
                header.addEventListener('click', () => {
                    const isExpanded = header.getAttribute('aria-expanded') === 'true';
                    
                    // Close all others
                    accordionHeaders.forEach(h => {
                        h.setAttribute('aria-expanded', 'false');
                    });
                    
                    // Toggle current
                    if (!isExpanded) {
                        header.setAttribute('aria-expanded', 'true');
                    }
                });
            });
        });
    </script>

    <%- include('../layout/footer') %>
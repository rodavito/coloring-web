<%- include('../layout/header') %>

    <div class="hero">
        <div class="hero-box">
            <h1>Dibujos de <%= images.length> 0 ? images[0].category_name : 'Categoría' %></h1>
            <p>
                <%= locals.categoryIntro || 'Descarga e imprime los mejores dibujos para colorear.' %>
            </p>
        </div>
    </div>

    <% if (locals.categorySeoTitle && locals.categorySeo) { %>
        <div class="category-info-trigger">
            <button onclick="openSeoModal()" class="seo-trigger-btn">
                <svg viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
                </svg>
                <span><%= categorySeoTitle %></span>
            </button>
        </div>
    <% } %>

    <div class="grid">
        <% if (images.length===0) { %>
            <p style="text-align: center; grid-column: 1/-1; padding: 5rem; color: #999;">No se encontraron dibujos.
                ¡Vuelve pronto!</p>
            <% } %>

                <% images.forEach(img=> { %>
                    <div class="card">
                        <a href="/dibujo/<%= img.slug %>">
                            <% const displaySrc=img.cloudinary_url ||
                                `/assets/images/webp/${img.category_slug}/${img.filename}.webp`; %>
                                <img src="<%= displaySrc %>" alt="<%= img.alt_text %>" loading="lazy">
                        </a>

                        <script type="application/ld+json">
                        {
                          "@context": "https://schema.org/",
                          "@type": "ImageObject",
                          "contentUrl": "<%= displaySrc.startsWith('http') ? displaySrc : 'https://pintacolores.com' + displaySrc %>",
                          "url": "https://pintacolores.com/dibujo/<%= img.slug %>",
                          "creator": {
                            "@type": "Organization",
                            "name": "PintaColores"
                          },
                          "creditText": "PintaColores",
                          "copyrightNotice": "© PintaColores",
                          "license": "https://pintacolores.com/aviso-legal",
                          "acquireLicensePage": "https://pintacolores.com/aviso-legal",
                          "name": "<%= img.title.replace(/\"/g, '&quot;') %>"
                        }
                        </script>

                        <div class="card-info">
                            <div class="card-header">
                                <h3 class="card-title">
                                    <%= img.title %>
                                </h3>
                                <span class="card-category">
                                    <%= img.category_name %>
                                </span>
                            </div>
                            <div class="card-actions">
                                <a href="/dibujo/<%= img.slug %>" class="btn btn-view">Ver</a>
                                <% const downloadSrc=img.cloudinary_url ||
                                    `/assets/images/jpg/${img.category_slug}/${img.filename}.jpg`; %>
                                    <a href="<%= downloadSrc %>" download="<%= img.slug %>" class="btn btn-download-sq"
                                        title="Descargar">
                                        <svg class="icon-svg" viewBox="0 0 24 24" fill="#ffffff">
                                            <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" />
                                        </svg>
                                    </a>
                            </div>
                        </div>
                    </div>
                    <% }) %>
    </div>

    <% if (typeof locals !=='undefined' && locals.hasMore) { %>
        <div id="load-more-container" style="text-align: center; margin-top: 4rem; margin-bottom: 4rem;">
            <% const safeBaseUrl=locals.baseUrl || '/' ; const safeCurrentPage=locals.currentPage || 1; const
                sep=safeBaseUrl.includes('?') ? '&' : '?' ; const nextUrl=`${safeBaseUrl}${sep}page=${safeCurrentPage +
                1}`; %>
                <a href="<%= nextUrl %>" id="load-more-btn" class="btn btn-primary">
                    Ver más dibujos
                </a>
        </div>
        <% } %>

    <% if (locals.categorySeo && locals.categorySeoTitle) { %>
        <!-- Modal para SEO -->
        <div id="seoModal" class="modal-overlay">
            <div class="modal-content">
                <button class="modal-close" onclick="closeSeoModal()">&times;</button>
                <div class="modal-inner">
                    <h2 class="modal-title"><%= categorySeoTitle %></h2>
                    <div class="modal-body">
                        <%- locals.categorySeo %>
                    </div>
                </div>
            </div>
        </div>

        <style>
            .category-info-trigger {
                max-width: 1200px;
                margin: 0.5rem auto 2rem;
                padding: 0 1.5rem;
                text-align: center;
                animation: fadeIn 1s ease-out;
            }
            .seo-trigger-btn {
                display: inline-flex;
                align-items: center;
                gap: 0.8rem;
                background: linear-gradient(135deg, #ffffff 0%, #f7fafc 100%);
                padding: 0.7rem 2.2rem;
                border-radius: 50px;
                border: 2px solid var(--primary, #a9e3f6);
                color: #2d3748;
                font-size: 1.05rem;
                font-weight: 700;
                cursor: pointer;
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                box-shadow: 0 10px 20px rgba(169, 227, 246, 0.2);
                text-decoration: none;
            }
            .seo-trigger-btn:hover {
                transform: translateY(-4px) scale(1.02);
                background: white;
                box-shadow: 0 15px 30px rgba(169, 227, 246, 0.4);
                border-color: var(--secondary, #4a90e2);
                color: var(--secondary, #4a90e2);
            }
            .seo-trigger-btn svg {
                width: 22px;
                height: 22px;
                fill: var(--primary, #a9e3f6);
                transition: fill 0.3s ease;
            }
            .seo-trigger-btn:hover svg {
                fill: var(--secondary, #4a90e2);
                transform: rotate(15deg);
            }

            /* Estilos del Modal */
            .modal-overlay {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                width: 100%;
                height: 100vh;
                height: 100dvh;
                background: rgba(0, 0, 0, 0.4);
                backdrop-filter: blur(12px);
                z-index: 9999;
                display: flex;
                align-items: center;
                justify-content: center;
                opacity: 0;
                visibility: hidden;
                transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            }
            .modal-overlay.active {
                opacity: 1;
                visibility: visible;
            }
            .modal-content {
                background: white;
                width: 90%;
                max-width: 700px;
                max-height: 85vh;
                border-radius: 30px;
                position: relative;
                transform: scale(0.9) translateY(20px);
                transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
                overflow: hidden;
                box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            }
            .modal-overlay.active .modal-content {
                transform: scale(1) translateY(0);
            }
            .modal-close {
                position: absolute;
                top: 1.5rem;
                right: 1.5rem;
                background: #f7fafc;
                border: none;
                width: 40px;
                height: 40px;
                border-radius: 50%;
                font-size: 1.5rem;
                line-height: 40px;
                cursor: pointer;
                color: #718096;
                transition: all 0.2s;
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 10;
            }
            .modal-close:hover {
                background: #edf2f7;
                color: #2d3748;
                transform: rotate(90deg);
            }
            .modal-inner {
                padding: 3rem;
                overflow-y: auto;
                max-height: 85vh;
            }
            .modal-title {
                font-size: 1.8rem;
                font-weight: 800;
                color: #1a202c;
                margin-bottom: 2rem;
                line-height: 1.2;
                padding-right: 2rem;
            }
            .modal-body {
                font-size: 1.1rem;
                line-height: 1.8;
                color: #4a5568;
            }
            .modal-body p {
                margin-bottom: 1.5rem;
            }
            .modal-body strong {
                color: #2d3748;
            }

            @media (max-width: 768px) {
                .modal-inner {
                    padding: 2rem;
                }
                .modal-title {
                    font-size: 1.5rem;
                }
                .modal-body {
                    font-size: 1.05rem;
                }
            }
        </style>

        <script>
            function openSeoModal() {
                const modal = document.getElementById('seoModal');
                modal.classList.add('active');
                document.body.style.overflow = 'hidden';
            }
            function closeSeoModal() {
                const modal = document.getElementById('seoModal');
                modal.classList.remove('active');
                document.body.style.overflow = '';
            }
            // Cerrar al hacer clic fuera del contenido
            window.onclick = function(event) {
                const modal = document.getElementById('seoModal');
                if (event.target == modal) {
                    closeSeoModal();
                }
            }
            // Cerrar con tecla Escape
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') closeSeoModal();
            });
        </script>
    <% } %>

            <script>
                document.addEventListener('DOMContentLoaded', () => {
                    const btn = document.getElementById('load-more-btn');
                    const grid = document.querySelector('.grid');
                    const container = document.getElementById('load-more-container');

                    if (!btn) return;

                    btn.addEventListener('click', async (e) => {
                        e.preventDefault();
                        const url = btn.getAttribute('href');
                        btn.textContent = 'Cargando... ⏳';
                        btn.style.opacity = '0.7';
                        btn.style.pointerEvents = 'none';

                        try {
                            const response = await fetch(url);
                            const text = await response.text();
                            const parser = new DOMParser();
                            const html = parser.parseFromString(text, 'text/html');

                            // Extraer nuevas tarjetas
                            const newCards = html.querySelectorAll('.grid .card');
                            newCards.forEach(card => {
                                grid.appendChild(card);
                            });

                            // Actualizar o eliminar botón
                            const newBtn = html.getElementById('load-more-btn');
                            if (newBtn) {
                                btn.setAttribute('href', newBtn.getAttribute('href'));
                                btn.textContent = 'Ver más dibujos';
                                btn.style.opacity = '1';
                                btn.style.pointerEvents = 'auto';
                            } else {
                                container.remove();
                            }
                        } catch (err) {
                            console.error('Error:', err);
                            window.location.href = url; // Fallback
                        }
                    });
                });
            </script>

            <%- include('../layout/footer') %>
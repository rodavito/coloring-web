<%- include('../layout/header') %>

    <div style="display: flex; gap: 4rem; flex-wrap: wrap; margin-top: 3rem; animation: fadeIn 0.8s ease-out;">
        <div style="flex: 1.2; min-width: 300px;">
            <div class="printable-area"
                style="background: white; padding: 2.5rem; border-radius: var(--radius-lg); box-shadow: var(--shadow); border: 4px solid white;">
                <% const displaySrc=image.cloudinary_url ||
                    `/assets/images/webp/${image.category_slug}/${image.filename}.webp`; %>
                    <img src="<%= displaySrc %>" alt="<%= image.alt_text %>"
                        style="width: 100%; height: auto; display: block; filter: drop-shadow(0 10px 20px rgba(0,0,0,0.03));">
            </div>

            <div style="margin-top: 2rem; display: flex; gap: 1.5rem; flex-direction: column;">
                <% const downloadSrc=image.cloudinary_url ||
                    `/assets/images/jpg/${image.category_slug}/${image.filename}.jpg`; %>
                    <a href="<%= downloadSrc %>" download="<%= image.slug %>" class="btn btn-primary"
                        style="width: 100%; padding: 1.5rem; font-size: 1.2rem; border-radius: var(--pill); display: flex; align-items: center; justify-content: center; gap: 10px;">
                        <svg class="icon-svg" viewBox="0 0 24 24" width="24" height="24" fill="white">
                            <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" />
                        </svg>
                        Descargar JPG
                    </a>

                    <button onclick="window.print()" class="btn btn-secondary"
                        style="width: 100%; padding: 1.5rem; font-size: 1.2rem; border-radius: var(--pill); display: flex; align-items: center; justify-content: center; gap: 10px; background: #f0fdf4; color: #166534; border: 2px solid #bbf7d0;">
                        🖨️ Imprimir / Generar PDF
                    </button>
            </div>

            <style>
                @media print {

                    /* 1. LIMPIEZA */
                    #cookie-banner,
                    .floating-decor,
                    .decor-item,
                    header,
                    footer,
                    nav,
                    .ad-slot,
                    button,
                    .btn,
                    [style*="flex: 0.8"],
                    h1,
                    h3,
                    p,
                    .tag-link {
                        display: none !important;
                    }

                    /* 2. ELIMINAR PÁGINAS EXTRA */
                    html,
                    body {
                        height: 100% !important;
                        width: 100% !important;
                        margin: 0 !important;
                        padding: 0 !important;
                        overflow: hidden !important;
                        break-after: avoid !important;
                        break-before: avoid !important;
                        background: white !important;
                    }

                    /* 3. CONTENEDOR AJUSTADO Y LIMPIO */
                    .printable-area {
                        position: fixed !important;
                        top: 50% !important;
                        left: 50% !important;
                        transform: translate(-50%, -50%) !important;
                        width: 100% !important;
                        height: 100% !important;
                        padding: 0.5cm 1cm 1.8cm 1cm !important;
                        box-sizing: border-box !important;

                        /* ESTO QUITA LA SOMBRA Y EL BORDE QUE VES ARRIBA */
                        box-shadow: none !important;
                        border: none !important;
                        border-radius: 0 !important;
                        background: white !important;
                    }

                    /* 4. IMAGEN PROPORCIONAL */
                    .printable-area img {
                        display: block !important;
                        /* Centramos la imagen dentro del contenedor fixed */
                        margin: 0 auto !important;
                        max-width: 100% !important;
                        max-height: 90vh !important;
                        object-fit: contain !important;
                        /* Quitamos filtros de sombra por si acaso */
                        filter: none !important;
                    }

                    /* 5. CONFIGURACIÓN DE PÁGINA */
                    @page {
                        size: auto;
                        margin: 0;
                    }
                }

                /* --- AJUSTE ESPECÍFICO PARA CELULARES --- */
                /* Si la pantalla es de menos de 768px (móvil) aplicamos esto */
                @media (max-width: 768px) {
                    .printable-area {
                        /* Padding equilibrado: 2cm arriba/lados y 3cm abajo para el logo */
                        padding: 2cm 1.5cm 3cm 1.5cm !important;
                        display: flex !important;
                        align-items: center !important;
                        /* Fuerza el centrado vertical en el espacio libre */
                        justify-content: center !important;
                    }

                    .printable-area img {
                        /* Bajamos un poquito más el alto para que la imagen "flote" con aire */
                        max-height: 70vh !important;
                        width: auto !important;
                    }

                    /* 5. CONFIGURACIÓN DE PÁGINA */
                    @page {
                        size: auto;
                        margin: 0;
                    }
                }
            </style>
        </div>
        <script>
            function imprimir() {
                window.print();
            }
        </script>
        <div style="flex: 0.8; min-width: 300px;">
            <a href="/categoria/<%= image.category_slug %>"
                style="text-decoration: none; background: #f0f7ff; color: var(--secondary); padding: 0.6rem 1.5rem; border-radius: var(--pill); font-weight: 700; font-size: 0.9rem; margin-bottom: 2rem; display: inline-block; transition: var(--transition);">
                <%= image.category_name %>
            </a>
            <h1
                style="font-size: 3.5rem; font-weight: 800; margin-bottom: 1.5rem; color: var(--text); letter-spacing: -2px; line-height: 1.1;">
                <%= image.title %>
            </h1>

            <div
                style="margin: 2rem 0; padding: 2.5rem; background: var(--white); border-radius: var(--radius-lg); border: 2px solid var(--border); box-shadow: var(--shadow);">
                <h3
                    style="margin-bottom: 1rem; font-size: 1.3rem; display: flex; align-items: center; gap: 12px; font-weight: 800;">
                    Descripción
                </h3>
                <p style="color: #666; font-size: 1.15rem; line-height: 1.8; font-weight: 500;">
                    <%= image.description
                        || '¡Un dibujo increíble diseñado con amor para que te diviertas coloreando y desarrolles tu creatividad!'
                        %>
                </p>
            </div>

            <div style="margin-bottom: 3rem;">
                <h3 style="margin-bottom: 1.2rem; font-size: 1.1rem; color: var(--text-light); font-weight: 700;">
                    Palabras clave</h3>
                <div style="display: flex; gap: 0.8rem; flex-wrap: wrap;">
                    <% if (image.tags) { %>
                        <% image.tags.split(',').forEach(tag=> { %>
                            <a href="/search?q=<%= encodeURIComponent(tag.trim()) %>" class="tag-link"
                                style="text-decoration: none; background: white; padding: 0.6rem 1.2rem; border-radius: var(--pill); font-weight: 600; font-size: 0.9rem; border: 1px solid var(--border); color: #666; transition: var(--transition);">
                                #<%= tag.trim() %>
                            </a>
                            <% }) %>
                                <% } %>
                </div>
            </div>

            <div class="ad-slot"
                style="height: 300px; display: flex; align-items: center; justify-content: center; background: #FFF9FA; border-color: #FFE0E6; border-radius: var(--radius-lg);">
                <!-- Ad Slot -->
            </div>
        </div>
    </div>

    <div class="ad-slot"
        style="margin-top: 5rem; height: 150px; background: #FFF9FA; border: 1px dashed #FFE0E6; border-radius: var(--radius-lg);">
        <!-- Ad Slot Inferior -->
    </div>

    <%- include('../layout/footer') %>
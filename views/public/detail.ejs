<%- include('../layout/header') %>

    <div class="detail-layout">

        <div class="detail-image-col">
            <div class="printable-area"
                style="background: white; padding: 2.5rem; border-radius: var(--radius-lg); box-shadow: var(--shadow); border: 4px solid white;">
                <% const displaySrc=image.cloudinary_url ||
                    `/assets/images/webp/${image.category_slug}/${image.filename}.webp`; %>
                    <img src="<%= displaySrc %>" alt="<%= image.alt_text %>"
                        style="width: 100%; height: auto; display: block; filter: drop-shadow(0 10px 20px rgba(0,0,0,0.03));">
            </div>

            <div style="margin-top: 2rem; display: flex; gap: 1.5rem; flex-direction: column;">
                <% const downloadSrc=image.cloudinary_url ? image.cloudinary_url.replace(/\.webp$/, '.jpg' ) :
                    `/assets/images/jpg/${image.category_slug}/${image.filename}.jpg`; %>

                    <a href="<%= downloadSrc %>" download="<%= image.slug %>.jpg" class="btn btn-primary"
                        style="width: 100%; padding: 1.5rem; font-size: 1.2rem; border-radius: var(--pill); display: flex; align-items: center; justify-content: center; gap: 10px;">
                        <svg class="icon-svg" viewBox="0 0 24 24" width="24" height="24" fill="white">
                            <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" />
                        </svg>
                        Descargar JPG
                    </a>

                    <button onclick="imprimirImagenSolo('<%= displaySrc %>')" class="btn btn-secondary"
                        style="width: 100%; padding: 1.5rem; font-size: 1.2rem; border-radius: var(--pill); display: flex; align-items: center; justify-content: center; gap: 10px; cursor: pointer; border: none;">
                        <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
                            <path d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"/>
                        </svg>
                        Imprimir / Generar PDF
                    </button>
            </div>
        </div>
        <div class="detail-info-col">
            <a href="/categoria/<%= image.category_slug %>" class="detail-category-badge">
                <%= image.category_name %>
            </a>

            <h1 class="detail-title">
                <%= image.title %>
            </h1>

            <div class="detail-description">
                <h2 class="detail-description-title">Descripción y Consejos</h2>
                <div class="detail-description-body">
                    <%- image.description
                        || '¡Un dibujo increíble diseñado con amor para que te diviertas coloreando! Descarga este dibujo de '
                        + image.title + ' y deja volar tu imaginación con tus colores favoritos.' %>
                </div>
            </div>

            <% if (image.tags) { %>
                <div class="detail-tags">
                    <span class="detail-tags-label">Palabras clave</span>
                    <div class="detail-tags-list">
                        <% image.tags.split(',').forEach(tag=> { %>
                            <a href="/buscar?q=<%= encodeURIComponent(tag.trim()) %>" class="tag-link">
                                #<%= tag.trim() %>
                            </a>
                            <% }) %>
                    </div>
                </div>
                <% } %>

                    <div class="ad-slot"
                        style="height: 300px; display: flex; align-items: center; justify-content: center; background: #FFF9FA; border: 1px dashed #FFE0E6; border-radius: var(--radius-lg);">
                    </div>
        </div>
    </div>
    <div class="ad-slot"
        style="margin: 3rem auto; max-width: 1200px; height: 150px; background: #FFF9FA; border: 1px dashed #FFE0E6; border-radius: var(--radius-lg);">
    </div>

    <script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "ImageObject",
  "contentUrl": "https://pintacolores.com<%= image.cloudinary_url || '/assets/images/webp/' + image.category_slug + '/' + image.filename + '.webp' %>",
  "creator": { "@type": "Organization", "name": "PintaColores" },
  "name": "<%= image.title %>",
  "license": "https://pintacolores.com/aviso-legal"
}
</script>

    <!-- Overlay de impresión: solo visible al imprimir -->
    <div id="print-overlay">
        <img id="print-overlay-img" src="" alt="Imprimir">
    </div>

    <script>
        function imprimirImagenSolo(src) {
            var img = document.getElementById('print-overlay-img');
            
            // Primero preparamos la imagen
            img.onload = function() {
                document.body.classList.add('printing');
                
                // Pequeño delay opcional para que el navegador "chupe" bien la imagen al layout
                setTimeout(function() {
                    window.print();
                }, 100);
            };
            
            img.src = src;

            // Escuchamos cuando se cierra el diálogo de impresión (imprima o cancele)
            // Fallback: si por alguna razón afterprint no se dispara
            // Limpiamos al volver a enfocar la ventana
            window.addEventListener('focus', function onFocus() {
                if (document.body.classList.contains('printing')) {
                    document.body.classList.remove('printing');
                    img.src = '';
                }
                window.removeEventListener('focus', onFocus);
            }, { once: true });
        }
    </script>

    <style>
        /* ===== OVERLAY DE IMPRESIÓN ===== */
        #print-overlay {
            display: none;
        }

        /* Al imprimir: ocultar todo y mostrar solo la imagen */
        @media print {
            @page { margin: 8mm; }

            body.printing > *:not(#print-overlay) {
                display: none !important;
            }

            body.printing #print-overlay {
                display: flex !important;
                position: fixed;
                inset: 0;
                width: 100%;
                height: 100%;
                background: white;
                align-items: center;
                justify-content: center;
                z-index: 99999;
            }

            body.printing #print-overlay img {
                max-width: 100%;
                max-height: 100%;
                width: auto;
                height: auto;
                object-fit: contain;
            }
        }


        /* El Layout de dos columnas en PC */
        .detail-layout {
            display: flex;
            gap: 3.5rem;
            flex-wrap: wrap;
            margin-top: 3rem;
            align-items: flex-start;
        }

        /* Columna Imagen: Ocupa un poco más de espacio y es pegajosa */
        .detail-image-col {
            flex: 1.2;
            min-width: 300px;
            position: sticky;
            top: 40px;
        }

        /* Columna Texto: Se adapta al espacio restante */
        .detail-info-col {
            flex: 1;
            min-width: 300px;
        }

        .detail-category-badge {
            text-decoration: none;
            background: #f0f7ff;
            color: var(--secondary);
            padding: 0.5rem 1.2rem;
            border-radius: var(--pill);
            font-weight: 700;
            font-size: 0.85rem;
            margin-bottom: 1.2rem;
            display: inline-block;
        }

        .detail-title {
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 1.5rem;
            color: var(--text);
            line-height: 1.2;
        }

        .detail-description {
            margin-bottom: 2rem;
            padding-left: 1.25rem;
            border-left: 4px solid var(--primary, #f9a8d4);
        }

        .detail-description-title {
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            color: #aaa;
            margin-bottom: 1rem;
        }

        .detail-description-body {
            color: #444;
            font-size: 1.1rem;
            line-height: 1.7;
        }

        .detail-tags-list {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .tag-link {
            text-decoration: none;
            background: #f8f8f8;
            padding: 0.4rem 1rem;
            border-radius: var(--pill);
            font-weight: 600;
            font-size: 0.85rem;
            border: 1px solid #eee;
            color: #666;
        }

        /* Ajustes para Móvil */
        @media (max-width: 900px) {
            .detail-layout {
                flex-direction: column;
                gap: 2rem;
            }

            .detail-image-col {
                position: static;
                width: 100%;
            }

            .detail-title {
                font-size: 1.8rem;
            }
        }
    </style>

    <%- include('../layout/footer') %>
<%- include('../layout/header') %>

    <div class="legal-container">
        <nav style="margin-bottom: 2rem; font-size: 0.9rem; color: var(--text-light);">
            <a href="/" style="color: var(--secondary); text-decoration: none;">Inicio</a>
            <span style="margin: 0 0.5rem;">&rsaquo;</span>
            <span>Artículos</span>
        </nav>

        <div class="articles-header"
            style="text-align: center; margin-bottom: 5rem; padding: 4rem 2rem; animation: fadeInDown 1s ease-out; background: linear-gradient(135deg, rgba(252, 228, 236, 0.3) 0%, rgba(225, 245, 254, 0.3) 50%, rgba(255, 249, 196, 0.3) 100%); border-radius: 40px; border: 1px solid rgba(255,255,255,0.5);">
            <h1
                style="font-size: 3.5rem; color: var(--secondary); margin-bottom: 1rem; font-weight: 800; letter-spacing: -2px;">
                Artículos y guías útiles</h1>
            <p style="color: #555; font-size: 1.25rem; font-family: 'Quicksand', sans-serif; max-width: 700px; margin: 0 auto;">Contenido informativo y
                práctico con consejos, ideas y recursos para aprender y disfrutar actividades creativas en todas las
                edades.</p>
        </div>

        <div class="articles-grid">
            <% const colors = ['#A9E3F6', '#E2F0CB', '#FCE4EC', '#FFF9C4']; %>
            <% articles.forEach((article, index)=> { %>
                <% const accentColor = colors[index % colors.length]; %>
                <a href="/articulo/<%= article.slug %>" class="article-card"
                    style="animation: fadeInUp 0.8s ease-out <%= index * 0.15 %>s both; border-top: 5px solid <%= accentColor %>;">
                    <div class="article-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                            stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                        </svg>
                    </div>
                    <div class="article-info">
                        <div class="article-meta">
                            <span class="article-tag">
                                <%= article.tag || 'Lectura' %>
                            </span>
                            <span class="article-time">
                                <svg style="width: 14px; height: 14px; vertical-align: middle; margin-right: 4px; margin-top: -2px;"
                                    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                    stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <polyline points="12 6 12 12 16 14"></polyline>
                                </svg>
                                <%= article.reading_time || '5 min' %>
                            </span>
                        </div>
                        <h2 class="article-title">
                            <%= article.title %>
                        </h2>
                        <p class="article-excerpt">
                            <%= article.content.replace(/<[^>]*>?/gm, '').substring(0, 160) %>...
                        </p>
                    </div>
                    <div class="article-arrow">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                            stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6"></polyline>
                        </svg>
                    </div>
                </a>
                <% }) %>

                    <% if (articles.length===0) { %>
                        <div style="text-align: center; padding: 6rem 0; animation: fadeIn 1s ease;">
                            <p style="color: var(--text-light); font-size: 1.1rem; font-weight: 500;">Aún no hay
                                artículos publicados. ¡Vuelve pronto!</p>
                        </div>
                        <% } %>
        </div>
    </div>

    <style>
        .legal-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 2rem 1.5rem 8rem;
        }

        .articles-grid {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .article-card {
            display: flex;
            gap: 2rem;
            padding: 2.5rem 2rem;
            background: #fdfdfd;
            border-radius: 24px;
            border: 1px solid rgba(0, 0, 0, 0.05);
            text-decoration: none;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            align-items: center;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
            position: relative;
            overflow: hidden;
        }

        .article-card:hover {
            transform: translateY(-8px) scale(1.01);
            box-shadow: 0 20px 40px rgba(169, 227, 246, 0.15);
            border-color: var(--primary);
        }

        .article-icon {
            background: #fff5f5;
            width: 65px;
            height: 65px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 18px;
            flex-shrink: 0;
            color: #333;
            transition: all 0.3s ease;
        }

        .article-card:hover .article-icon {
            transform: rotate(-5deg);
            background: var(--accent);
        }

        .article-icon svg {
            width: 30px;
            height: 30px;
        }

        .article-info {
            flex: 1;
        }

        .article-meta {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            margin-bottom: 0.8rem;
        }

        .article-tag {
            background: #fff;
            color: var(--secondary);
            padding: 4px 14px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            border: 1px solid rgba(0,0,0,0.05);
        }

        .article-time {
            color: #999;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
        }

        .article-title {
            font-size: 1.6rem;
            color: var(--secondary);
            margin-bottom: 0.6rem;
            line-height: 1.3;
            font-weight: 700;
            font-family: 'Quicksand', sans-serif;
        }

        .article-excerpt {
            font-size: 1rem;
            color: #777;
            margin: 0;
            line-height: 1.6;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            max-width: 90%;
        }

        .article-arrow {
            color: var(--primary);
            opacity: 0.4;
            transition: all 0.3s ease;
            padding: 10px;
        }

        .article-card:hover .article-arrow {
            opacity: 1;
            transform: translateX(5px);
        }

        .article-arrow svg {
            width: 24px;
            height: 24px;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @media (max-width: 768px) {
            .articles-header h1 {
                font-size: 2.5rem;
            }

            .article-card {
                flex-direction: column;
                gap: 1.5rem;
                text-align: center;
                padding: 2.5rem 1.5rem;
            }

            .article-meta {
                justify-content: center;
            }

            .article-icon {
                width: 75px;
                height: 75px;
            }

            .article-excerpt {
                max-width: 100%;
            }

            .article-arrow {
                display: none;
            }
        }
    </style>

    <%- include('../layout/footer') %>
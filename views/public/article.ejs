<%- include('../layout/header') %>

<div class="legal-container article-content">
    <nav style="margin-bottom: 2rem; font-size: 0.9rem; color: var(--text-light);">
        <a href="/" style="color: var(--secondary); text-decoration: none;">Inicio</a> 
        <span style="margin: 0 0.5rem;">&rsaquo;</span> 
        <span style="color: var(--text-light);">Artículos</span>
        <span style="margin: 0 0.5rem;">&rsaquo;</span> 
        <span><%= article.title %></span>
    </nav>

    <h1><%= article.title %></h1>
    
    <div class="article-body">
        <%- article.content %>
    </div>

    <div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
        <div style="font-size: 0.9rem; color: var(--text-light);">
            Publicado el <%= new Date(article.created_at).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' }) %>
        </div>
        <div style="display: flex; gap: 1rem;">
            <a href="/" class="btn btn-primary" style="padding: 0.6rem 1.2rem; font-size: 0.9rem;">Ver dibujos para colorear</a>
        </div>
    </div>
</div>

<style>
    .article-body {
        font-size: 1.1rem;
        line-height: 1.8;
        color: var(--text);
        overflow: hidden; /* Clears floats */
    }
    .article-body h2 {
        color: var(--secondary);
        margin: 2.5rem 0 1.2rem;
        font-size: 1.8rem;
        clear: both;
    }
    .article-body h3 {
        color: var(--text);
        margin: 2rem 0 1rem;
        font-size: 1.4rem;
        clear: both;
    }
    .article-body p {
        margin-bottom: 1.5rem;
    }
    .article-body img {
        max-width: 400px;
        width: 100%;
        height: auto;
        border-radius: var(--radius-md);
        margin: 1rem 0;
        box-shadow: var(--shadow);
        transition: var(--transition);
        display: block;
        margin-left: auto;
        margin-right: auto;
    }
    
    /* Alternating floats for larger screens */
    @media (min-width: 769px) {
        .article-body img {
            max-width: 350px;
            margin: 1rem;
        }
        .article-body img:nth-of-type(odd) {
            float: left;
            margin-left: 0;
            margin-right: 2rem;
        }
        .article-body img:nth-of-type(even) {
            float: right;
            margin-right: 0;
            margin-left: 2rem;
        }
    }

    .article-body ul, .article-body ol {
        margin-bottom: 1.5rem;
        padding-left: 1.5rem;
        overflow: hidden;
    }
    .article-body li {
        margin-bottom: 0.8rem;
    }
    @media (max-width: 768px) {
        .article-body h2 { font-size: 1.5rem; }
        .article-body h3 { font-size: 1.2rem; }
        .article-body img { 
            max-width: 100%; 
            float: none !important;
            margin: 2rem 0 !important;
        }
    }
</style>

<%- include('../layout/footer') %>

<%- include('../layout/header') %>

    <div style="display: flex; gap: 4rem; animation: fadeIn 0.8s ease-out;">
        <div style="flex: 1.2;">
            <h1 style="letter-spacing: -1px; margin-bottom: 2rem;">Artículos Publicados 📚</h1>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 1.5rem;">
                <% articles.forEach(article => { %>
                    <div style="background: white; padding: 1.5rem; border-radius: 20px; box-shadow: var(--shadow); border: 1px solid var(--border); display: flex; flex-direction: column; transition: var(--transition);"
                        onmouseover="this.style.transform='translateY(-5px)'"
                        onmouseout="this.style.transform='translateY(0)'">
                        <div
                            style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                            <div style="font-size: 1.5rem;">📝</div>
                            <div style="display: flex; gap: 0.5rem;">
                                <a href="<%= adminPath %>/articles/edit/<%= article.id %>" title="Editar"
                                    style="text-decoration: none; font-size: 1.2rem;">✏️</a>
                                <form action="<%= adminPath %>/articles/delete/<%= article.id %>" method="POST"
                                    onsubmit="return confirm('¿Estás seguro de eliminar este artículo?')">
                                    <button type="submit"
                                        style="background: none; border: none; cursor: pointer; font-size: 1.2rem; padding: 0;">🗑️</button>
                                </form>
                            </div>
                        </div>
                        <strong style="font-size: 1.1rem; color: var(--text);">
                            <%= article.title %>
                        </strong>
                        <div style="display: flex; gap: 0.5rem; margin-top: 5px; flex-wrap: wrap;">
                            <span style="font-size: 0.75rem; color: var(--secondary); background: #f0f7ff; padding: 2px 8px; border-radius: 12px; font-weight: 600;"><%= article.tag || 'Lectura' %></span>
                            <span style="font-size: 0.75rem; color: #888; background: #f5f5f5; padding: 2px 8px; border-radius: 12px;"><%= article.reading_time || '5 min' %></span>
                        </div>
                        <span style="font-size: 0.8rem; color: #bbb; margin-top: 8px; display: block;">/articulo/<%= article.slug %></span>
                        <p
                            style="font-size: 0.9rem; color: #666; margin-top: 0.5rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; line-clamp: 3;">
                            <%= article.content.replace(/<[^>]*>?/gm, '') %>
                        </p>
                    </div>
                <% }) %>
                <% if (articles.length === 0) { %>
                    <p style="color: #999;">No hay artículos creados aún.</p>
                <% } %>
            </div>
        </div>

        <div style="flex: 0.8;">
            <div class="admin-form" style="margin: 0; position: sticky; top: 100px;">
                <h2 style="margin-bottom: 0.5rem; font-size: 1.5rem;">Escribir nuevo ✨</h2>
                <p style="color: #888; margin-bottom: 2rem; font-size: 0.9rem;">Agrega contenido de valor para tus usuarios y AdSense.</p>
                <form action="<%= adminPath %>/articles/create" method="POST">
                    <div class="form-group">
                        <label for="title">Título del Artículo</label>
                        <input type="text" name="title" id="title" placeholder="Ej: Los beneficios de colorear" required>
                    </div>
                    <div style="display: flex; gap: 1rem;">
                        <div class="form-group" style="flex: 1;">
                            <label for="tag">Etiqueta</label>
                            <input type="text" name="tag" id="tag" placeholder="Ej: Educación" value="Lectura">
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label for="reading_time">Tiempo</label>
                            <input type="text" name="reading_time" id="reading_time" placeholder="Ej: 5 min" value="5 min">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="content">Contenido (HTML permitido)</label>
                        <textarea name="content" id="content" rows="12"
                            placeholder="Escribe aquí tu artículo..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-secondary" style="width: 100%; padding: 1rem;">Publicar Artículo</button>
                </form>
            </div>
        </div>
    </div>

<%- include('../layout/footer') %>

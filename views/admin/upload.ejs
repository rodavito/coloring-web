<%- include('../layout/header') %>

    <div class="admin-form" style="max-width: 800px; animation: fadeIn 0.8s ease-out;">
        <h1 style="margin-bottom: 0.5rem; letter-spacing: -1px;">Subir Nuevo Dibujo ✨</h1>
        <p style="color: #888; margin-bottom: 2.5rem;">Completa los detalles para publicar tu nueva creación.</p>

        <form action="<%= adminPath %>/upload" method="POST" enctype="multipart/form-data">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <div style="flex: 1; min-width: 300px;">
                    <div style="margin-bottom: 2rem;">
                        <label
                            style="display: block; width: 100%; aspect-ratio: 16/9; border: 2px dashed #ddd; border-radius: 20px; display: flex; align-items: center; justify-content: center; cursor: pointer; background: #fafafa; transition: var(--transition);"
                            onmouseover="this.style.borderColor='var(--primary)'; this.style.background='#fff0f3';"
                            onmouseout="this.style.borderColor='#ddd'; this.style.background='#fafafa';">
                            <input type="file" name="image" required style="display: none;"
                                onchange="previewImage(this)">
                            <div id="upload-placeholder" style="text-align: center;">
                                <span style="font-size: 2rem;">🖼️</span>
                                <p style="color: #888; margin-top: 0.5rem; font-size: 0.9rem;">Haz clic para subir JPG o
                                    WEBP</p>
                            </div>
                        </label>
                        <img id="preview" style="width: 100%; border-radius: 20px; margin-top: 1rem; display: none;">
                    </div>

                <div>
                    <div class="form-group">
                        <label for="category_id">Categoría Principal</label>
                        <select name="category_id" id="category_id" required onchange="filterSubcats()">
                            <option value="" disabled selected>Selecciona una categoría</option>
                            <% categories.forEach(cat => { %>
                                <option value="<%= cat.id %>">
                                    <%= cat.name %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="subcategory_id">Subcategoría (Opcional)</label>
                        <select name="subcategory_id" id="subcategory_id">
                            <option value="">Ninguna</option>
                            <% subcategories.forEach(subcat => { %>
                                <option value="<%= subcat.id %>" data-category="<%= subcat.category_id %>">
                                    <%= subcat.name %>
                                </option>
                            <% }) %>
                        </select>
                        <small style="color: #888;">El dibujo también aparecerá en la categoría principal.</small>
                    </div>
                </div>

                <div>
                    <div class="form-group">
                        <label for="title">Título SEO ✨</label>
                        <input type="text" name="title" id="title" placeholder="Ej: Lindo gatito para colorear"
                            required>
                    </div>

                    <div class="form-group">
                        <label for="alt_text">Texto Alternativo (Alt Text)</label>
                        <input type="text" name="alt_text" id="alt_text" placeholder="Descripción breve para Google">
                    </div>

                    <div class="form-group">
                        <label for="tags">Tags (separados por coma)</label>
                        <input type="text" name="tags" id="tags" placeholder="animales, tierno, kawaii">
                    </div>
                </div>
            </div>

            <div class="form-group" style="margin-top: 1rem;">
                <label for="description">Descripción detallada (podés usar HTML: &lt;p&gt;, &lt;strong&gt;, etc.)</label>
                <textarea name="description" id="description" rows="6"
                    placeholder="Escribe una pequeña historia o descripción para este dibujo...&#10;Podés usar HTML: &lt;p&gt;párrafo&lt;/p&gt; &lt;strong&gt;negrita&lt;/strong&gt;"></textarea>
                <small style="color: #888;">Ejemplo: &lt;p&gt;Descripción del dibujo.&lt;/p&gt; &lt;p&gt;Otro párrafo con &lt;strong&gt;énfasis&lt;/strong&gt;.&lt;/p&gt;</small>
            </div>

            <button type="submit" class="btn btn-primary"
                style="width: 100%; padding: 1.2rem; font-size: 1.1rem; margin-top: 1rem;">
                PUBLICAR DIBUJO ✅
            </button>
        </form>
    </div>

    <script>
        function previewImage(input) {
            const reader = new FileReader();
            const placeholder = document.getElementById('upload-placeholder');
            reader.onload = function () {
                const output = document.getElementById('preview');
                output.src = reader.result;
                output.style.display = 'block';
                if (placeholder) placeholder.style.display = 'none';
            };
            if (input.files && input.files[0]) {
                reader.readAsDataURL(input.files[0]);
            }
        }

        function filterSubcats() {
            const catId = document.getElementById('category_id').value;
            const subcatSelect = document.getElementById('subcategory_id');
            const options = subcatSelect.querySelectorAll('option');
            
            subcatSelect.value = ''; // Reset selection
            
            options.forEach(opt => {
                if(opt.value === '') {
                    opt.style.display = ''; // Siempre mostrar 'Ninguna'
                } else if(opt.getAttribute('data-category') === catId) {
                    opt.style.display = '';
                } else {
                    opt.style.display = 'none';
                }
            });
        }
        
        // Execute on load if there's a default category
        if(document.getElementById('category_id').value) {
            filterSubcats();
        }
    </script>

    <%- include('../layout/footer') %>
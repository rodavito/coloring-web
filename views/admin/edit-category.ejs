<%- include('../layout/header') %>

    <div style="max-width: 600px; margin: 2rem auto; animation: fadeIn 0.8s ease-out;">
        <h1 style="letter-spacing: -1px; margin-bottom: 2rem;">Editar Categoría: <%= category.name %> ✨
        </h1>

        <div class="admin-form" style="margin: 0;">
            <form action="<%= adminPath %>/categories/edit/<%= category.id %>" method="POST">
                <div class="form-group">
                    <label for="name">Nombre de la Categoría</label>
                    <input type="text" name="name" id="name" value="<%= category.name %>" required>
                </div>
                <div class="form-group">
                    <label for="emoji">Emoji Representativo (Ej: 🚀)</label>
                    <input type="text" name="emoji" id="emoji" value="<%= category.emoji %>" placeholder="🚀"
                        maxlength="10">
                </div>
                <div class="form-group">
                    <label for="intro_text">Texto Introductorio (SEO)</label>
                    <textarea name="intro_text" id="intro_text" rows="4" required><%= category.intro_text %></textarea>
                    <small style="color: #888;">Este texto aparecerá debajo del título en la página de la
                        categoría.</small>
                </div>
                <div class="form-group">
                    <label for="seo_title">Título del bloque informativo (Modal)</label>
                    <input type="text" name="seo_title" id="seo_title" value="<%= category.seo_title || '' %>" placeholder="Ej: ✨ Descubre más sobre estos dibujos">
                    <small style="color: #888;">Este título aparecerá arriba del grid y abrirá el texto en una ventana.</small>
                </div>
                <div class="form-group">
                    <label for="seo_text">Contenido Informativo (Ventana flotante)</label>
                    <textarea name="seo_text" id="seo_text" rows="8" placeholder="Podés pegar aquí párrafos completos con HTML básico como &lt;p&gt;, &lt;strong&gt;, etc."><%= category.seo_text || '' %></textarea>
                    <small style="color: #888;">Este contenido se mostrará en una ventana emergente al hacer clic en el título. Ideal para SEO y AdSense.</small>
                </div>

                <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                    <button type="submit" class="btn btn-secondary" style="flex: 1; padding: 1rem;">Guardar
                        Cambios</button>
                    <a href="<%= adminPath %>/categories" class="btn"
                        style="flex: 1; padding: 1rem; background: #eee; color: #666; text-align: center;">Cancelar</a>
                </div>
            </form>
        </div>
    </div>

    <%- include('../layout/footer') %>
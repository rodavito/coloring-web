<%- include('../layout/header') %>

    <div class="admin-form" style="max-width: 800px; animation: fadeIn 0.8s ease-out;">
        <h1 style="margin-bottom: 0.5rem; letter-spacing: -1px;">Editar Dibujo ✨</h1>
        <p style="color: #888; margin-bottom: 2.5rem;">Modifica los detalles del dibujo "<%= image.title %>".</p>

        <form action="<%= adminPath %>/edit/<%= image.id %>" method="POST">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <div style="flex: 1; min-width: 300px;">
                    <div style="margin-bottom: 2rem;">
                        <div
                            style="width: 100%; aspect-ratio: 16/9; border-radius: 20px; overflow: hidden; border: 1px solid var(--border);">
                            <% const displaySrc=image.cloudinary_url ||
                                `/assets/images/webp/${image.category_slug}/${image.filename}.webp`; %>
                                <img src="<%= displaySrc %>" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <p style="color: #888; margin-top: 0.5rem; font-size: 0.8rem; text-align: center;">Vista previa
                            actual</p>
                    </div>

                <div>
                    <div class="form-group">
                        <label for="category_id">Categoría Principal</label>
                        <select name="category_id" id="category_id" required onchange="filterSubcats()">
                            <% categories.forEach(cat=> { %>
                                <option value="<%= cat.id %>" <%=image.category_id==cat.id ? 'selected' : '' %>>
                                    <%= cat.name %>
                                </option>
                                <% }) %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="subcategory_id">Subcategoría (Opcional)</label>
                        <select name="subcategory_id" id="subcategory_id">
                            <option value="">Ninguna</option>
                            <% subcategories.forEach(subcat => { %>
                                <option value="<%= subcat.id %>" data-category="<%= subcat.category_id %>" <%=image.subcategory_id==subcat.id ? 'selected' : '' %>>
                                    <%= subcat.name %>
                                </option>
                            <% }) %>
                        </select>
                        <small style="color: #888;">El dibujo también aparecerá en la categoría principal.</small>
                    </div>
                </div>

                <div>
                    <div class="form-group">
                        <label for="title">Título SEO ✨</label>
                        <input type="text" name="title" id="title" value="<%= image.title %>" required>
                    </div>

                    <div class="form-group">
                        <label for="alt_text">Texto Alternativo (Alt Text)</label>
                        <input type="text" name="alt_text" id="alt_text" value="<%= image.alt_text %>">
                    </div>

                    <div class="form-group">
                        <label for="tags">Tags (separados por coma)</label>
                        <input type="text" name="tags" id="tags" value="<%= image.tags %>">
                    </div>
                </div>
            </div>

            <div class="form-group" style="margin-top: 1rem;">
                <label for="description">Descripción detallada (podés usar HTML: &lt;p&gt;, &lt;strong&gt;, etc.)</label>
                <textarea name="description" id="description" rows="6"><%= image.description %></textarea>
                <small style="color: #888;">Ejemplo: &lt;p&gt;Descripción del dibujo.&lt;/p&gt; &lt;p&gt;Otro párrafo con &lt;strong&gt;énfasis&lt;/strong&gt;.&lt;/p&gt;</small>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <a href="<%= adminPath %>" class="btn"
                    style="flex: 1; padding: 1.2rem; text-align: center; background: #f1f5f9; color: #64748b;">CANCELAR</a>
                <button type="submit" class="btn btn-primary" style="flex: 2; padding: 1.2rem; font-size: 1.1rem;">
                    GUARDAR CAMBIOS ✅
                </button>
            </div>
        </form>
    </div>

    <script>
        function filterSubcats() {
            const catId = document.getElementById('category_id').value;
            const subcatSelect = document.getElementById('subcategory_id');
            const options = subcatSelect.querySelectorAll('option');
            
            // Si el trigger de onchange no es inicial, limpiar selección. 
            // Para eso verificamos un logica. Lo simplificaremos de forma que no resetee al cargar la página
            const currentSelected = subcatSelect.value;
            
            let foundCurrent = false;

            options.forEach(opt => {
                if(opt.value === '') {
                    opt.style.display = ''; // Siempre mostrar 'Ninguna'
                } else if(opt.getAttribute('data-category') === catId) {
                    opt.style.display = '';
                    if (opt.value === currentSelected) foundCurrent = true;
                } else {
                    opt.style.display = 'none';
                }
            });

            if (!foundCurrent && currentSelected !== '') {
                subcatSelect.value = '';
            }
        }
        
        // Execute on load if there's a default category
        if(document.getElementById('category_id').value) {
            filterSubcats();
        }
    </script>    

    <%- include('../layout/footer') %>
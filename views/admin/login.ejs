<%- include('../layout/header') %>

    <div class="admin-form" style="margin-top: 5rem;">
        <h1 style="text-align: center; margin-bottom: 2rem;">Login Administrador</h1>
        <% if (error) { %>
            <p style="color: red; text-align: center; margin-bottom: 1rem;">
                <%= error %>
            </p>
            <% } %>
                <form action="<%= adminPath %>/login" method="POST">
                    <div class="form-group">
                        <label for="username">Usuario</label>
                        <input type="text" name="username" id="username" required>
                    </div>
                    <div class="form-group">
                        <label for="password">Contraseña</label>
                        <input type="password" name="password" id="password" required>
                    </div>
                    <button type="submit" class="btn btn-primary" style="width: 100%;">Ingresar</button>
                </form>
    </div>

    <%- include('../layout/footer') %>